{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "build",
        "ci",
        "chore",
        "revert"
      ]
    ],
    "scope-enum": [
      1,
      "always",
      [
        "auth",
        "user",
        "doctor",
        "appointment",
        "vitals",
        "pharmacy",
        "ambulance",
        "complaint",
        "forum",
        "bff",
        "frontend",
        "helm",
        "ci",
        "infra",
        "deps"
      ]
    ],
    "subject-case": [2, "never", ["upper-case"]],
    "subject-max-length": [2, "always", 100],
    "body-max-line-length": [1, "always", 200]
  }
}
